{%- comment -%} Customer registration {%- endcomment -%}
<section class="px-account page-width">
  <div class="px-account__card" data-reveal>
    <h1 class="px-account__title">{{ 'customer.register.title' | t }}</h1>
    {%- form 'create_customer', novalidate: 'novalidate' -%}
      {{ form.errors | default_errors }}
      <div class="px-account__row">
        <div>
          <label for="FirstName">{{ 'customer.register.first_name' | t }}</label>
          <input type="text" id="FirstName" name="customer[first_name]" autocomplete="given-name">
        </div>
        <div>
          <label for="LastName">{{ 'customer.register.last_name' | t }}</label>
          <input type="text" id="LastName" name="customer[last_name]" autocomplete="family-name">
        </div>
      </div>
      <label for="RegisterEmail">{{ 'customer.register.email' | t }}</label>
      <input type="email" id="RegisterEmail" name="customer[email]" autocomplete="email" required>
      <label for="RegisterPassword">{{ 'customer.register.password' | t }}</label>
      <input type="password" id="RegisterPassword" name="customer[password]" autocomplete="new-password" required>
      <button type="submit" class="px-btn px-btn--primary px-btn--block">{{ 'customer.register.submit' | t }}</button>
    {%- endform -%}
    <p class="px-account__alt"><a href="{{ routes.account_login_url }}" class="px-account__link">{{ 'customer.login.title' | t }}</a></p>
  </div>
</section>

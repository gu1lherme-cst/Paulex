{%- comment -%} Customer login + password recovery {%- endcomment -%}
<section class="px-account page-width">
  <div class="px-account__card" data-reveal>
    <div id="login">
      <h1 class="px-account__title">{{ 'customer.login.title' | t }}</h1>
      {%- form 'customer_login', novalidate: 'novalidate' -%}
        {{ form.errors | default_errors }}
        <label for="CustomerEmail">{{ 'customer.login.email' | t }}</label>
        <input type="email" id="CustomerEmail" name="customer[email]" autocomplete="email" required>

        {%- if form.password_needed -%}
          <label for="CustomerPassword">{{ 'customer.login.password' | t }}</label>
          <input type="password" id="CustomerPassword" name="customer[password]" autocomplete="current-password" required>
          <a href="#recover" class="px-account__link" data-recover-toggle>{{ 'customer.login.forgot_password' | t }}</a>
        {%- endif -%}

        <button type="submit" class="px-btn px-btn--primary px-btn--block">{{ 'customer.login.submit' | t }}</button>
      {%- endform -%}

      <p class="px-account__alt">
        <a href="{{ routes.account_register_url }}" class="px-account__link">{{ 'customer.login.create_account' | t }}</a>
      </p>
    </div>

    <div id="recover" class="px-account__recover" hidden>
      <h2 class="px-account__title">{{ 'customer.login.forgot_password' | t }}</h2>
      {%- form 'recover_customer_password' -%}
        {{ form.errors | default_errors }}
        {%- if form.posted_successfully? -%}
          <p class="px-account__success">{{ 'general.newsletter.success' | t }}</p>
        {%- endif -%}
        <label for="RecoverEmail">{{ 'customer.login.email' | t }}</label>
        <input type="email" id="RecoverEmail" name="email" autocomplete="email" required>
        <button type="submit" class="px-btn px-btn--primary px-btn--block">{{ 'customer.login.submit' | t }}</button>
      {%- endform -%}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-recover-toggle]').forEach(function (el) {
    el.addEventListener('click', function (e) {
      e.preventDefault();
      document.getElementById('login').hidden = true;
      document.getElementById('recover').hidden = false;
    });
  });
</script>

<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="theme-color" content="{{ settings.color_primary }}">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- comment -%} Favicon {%- endcomment -%}
    {%- if settings.share_image != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.share_image | image_url: width: 32, height: 32 }}">
      <link rel="apple-touch-icon" href="{{ settings.share_image | image_url: width: 180, height: 180 }}">
    {%- endif -%}

    {%- comment -%} Title + SEO meta {%- endcomment -%}
    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; {{ 'general.meta.tags' | t: tags: current_tags | join: ', ' }}{% endif -%}
      {%- if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {%- render 'meta-tags' -%}

    {{ content_for_header }}

    {%- comment -%} CSS custom properties from theme settings {%- endcomment -%}
    {%- liquid
      assign body_font = settings.font_body
      assign heading_font = settings.font_heading
      assign body_font_bold = body_font | font_modify: 'weight', 'bold'

      # Fallbacks da marca: garantem cores válidas mesmo se a Shopify não
      # importar alguma configuração (ex.: o gradiente color_background no
      # upload por ZIP), evitando hero/seções em branco.
      assign c_primary = settings.color_primary | default: '#003DFF'
      assign c_accent = settings.color_accent | default: '#14D8FF'
      assign c_sale = settings.color_sale | default: '#FF1D25'
      assign c_text = settings.color_text | default: '#111111'
      assign c_bg = settings.color_background | default: '#FFFFFF'
      assign c_surface = settings.color_surface | default: '#F7F7F7'
      assign grad_hero = settings.gradient_hero
      if grad_hero == blank
        assign grad_hero = 'linear-gradient(135deg, ' | append: c_primary | append: ' 0%, ' | append: c_accent | append: ' 100%)'
      endif
    -%}
    {% style %}
      {{ body_font | font_face: font_display: 'swap' }}
      {{ body_font_bold | font_face: font_display: 'swap' }}
      {{ heading_font | font_face: font_display: 'swap' }}

      :root {
        --color-primary: {{ c_primary }};
        --color-primary-rgb: {{ c_primary | color_to_rgb | remove: 'rgb(' | remove: ')' }};
        --color-accent: {{ c_accent }};
        --color-accent-rgb: {{ c_accent | color_to_rgb | remove: 'rgb(' | remove: ')' }};
        --color-sale: {{ c_sale }};
        --color-success: #16a34a;
        --color-success-rgb: 22, 163, 74;
        --color-text: {{ c_text }};
        --color-text-rgb: {{ c_text | color_to_rgb | remove: 'rgb(' | remove: ')' }};
        --color-bg: {{ c_bg }};
        --color-surface: {{ c_surface }};
        --gradient-hero: {{ grad_hero }};

        --font-body-family: {{ body_font.family }}, {{ body_font.fallback_families }};
        --font-body-weight: {{ body_font.weight }};
        --font-heading-family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
        --font-heading-weight: {{ heading_font.weight }};
        --font-scale: {{ settings.font_scale | divided_by: 100.0 }};

        --page-width: {{ settings.page_width }}px;
        --radius: {{ settings.corner_radius }}px;
        --radius-sm: {{ settings.corner_radius | times: 0.5 | round }}px;
        --section-spacing: {{ settings.section_spacing }}px;
        --header-height: 76px;
        --header-height-scrolled: 60px;
      }
    {% endstyle %}

    {{ 'theme.css' | asset_url | stylesheet_tag }}

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
      window.PaulexSettings = {
        cartType: {{ settings.cart_type | json }},
        routes: {
          cart_add_url: {{ routes.cart_add_url | json }},
          cart_change_url: {{ routes.cart_change_url | json }},
          cart_update_url: {{ routes.cart_update_url | json }},
          cart_url: {{ routes.cart_url | json }},
          predictive_search_url: {{ routes.predictive_search_url | json }}
        },
        strings: {
          addedToCart: {{ 'products.product.added_to_cart' | t | json }},
          addToCartError: {{ 'products.product.add_to_cart_error' | t | json }},
          quantityError: {{ 'cart.errors.quantity' | t | json }},
          addToCart: {{ 'products.product.add_to_cart' | t | json }},
          soldOut: {{ 'products.product.sold_out' | t | json }},
          unavailable: {{ 'products.product.unavailable' | t | json }},
          inStock: {{ 'products.product.in_stock' | t | json }},
          lowStock: {{ 'products.product.low_stock' | t | json }},
          outOfStock: {{ 'products.product.out_of_stock' | t | json }},
          searching: {{ 'general.search.searching' | t | json }},
          searchError: {{ 'general.search.error' | t | json }},
          noResults: {{ 'general.search.no_results_short' | t | json }},
          products: {{ 'general.search.products' | t | json }},
          collections: {{ 'general.search.collections' | t | json }},
          pages: {{ 'general.search.pages' | t | json }},
          viewAll: {{ 'general.search.view_all' | t | json }}
        }
      };
    </script>
    <script src="{{ 'theme.js' | asset_url }}" defer></script>
    {%- if settings.animations_reveal -%}
      <link rel="modulepreload" href="{{ 'animations.js' | asset_url }}">
      <script src="{{ 'animations.js' | asset_url }}" defer></script>
    {%- endif -%}
  </head>

  <body class="template-{{ request.page_type | handle }} gradient">
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      {{ 'general.accessibility.skip_to_text' | t }}
    </a>

    {% sections 'header-group' %}

    <main id="MainContent" class="content-for-layout" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {%- comment -%} Cart drawer (rendered globally so it works from any page) {%- endcomment -%}
    {%- if settings.cart_type == 'drawer' -%}
      {% render 'cart-drawer' %}
    {%- endif -%}

    {%- comment -%} Search modal {%- endcomment -%}
    {% render 'search-modal' %}

    {%- comment -%} Floating WhatsApp {%- endcomment -%}
    {%- if settings.social_whatsapp != blank -%}
      <a
        class="px-whatsapp-fab"
        href="https://wa.me/{{ settings.social_whatsapp | remove: '+' | remove: ' ' | remove: '-' | remove: '(' | remove: ')' | remove: '.' }}"
        target="_blank"
        rel="noopener"
        aria-label="{{ 'general.social.whatsapp' | t }}"
      >
        {% render 'icon', name: 'whatsapp' %}
      </a>
    {%- endif -%}

    <div id="px-toast-region" class="px-toast-region" aria-live="polite" aria-atomic="true"></div>
  </body>
</html>

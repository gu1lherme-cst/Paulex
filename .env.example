# Copie este arquivo para ".env" e preencha conforme for habilitando recursos.
# Nenhuma destas variáveis é obrigatória para o app rodar.

# --- Pagamento online (Pix / cartão) ---
# URL pública da sua função serverless (veja server/README.md).
# Sem isto, o checkout finaliza pelo WhatsApp.
VITE_PAYMENTS_API=

# --- Backend na nuvem (Supabase) ---
# Sem isto, os dados ficam salvos no navegador (veja src/lib/cloud.ts).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

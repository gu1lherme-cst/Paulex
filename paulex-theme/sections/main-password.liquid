{%- comment -%} Password page content (rendered inside layout/password.liquid) {%- endcomment -%}
<h1 class="px-account__title">{{ shop.name }}</h1>
<p>{{ section.settings.message | default: 'Estamos preparando algo especial. Volte em breve.' }}</p>

{%- form 'storefront_password' -%}
  {{ form.errors | default_errors }}
  <label for="Password">Senha da loja</label>
  <input type="password" id="Password" name="password" required>
  <button type="submit" class="px-btn px-btn--primary px-btn--block">Entrar</button>
{%- endform -%}

<p style="margin-top:2rem">
  {%- form 'customer', class: 'px-newsletter__form' -%}
    <input type="hidden" name="contact[tags]" value="prelaunch">
    <label for="PwEmail">Avise-me no lançamento</label>
    <div class="px-newsletter__row" style="margin-top:.8rem">
      <input type="email" id="PwEmail" name="contact[email]" placeholder="Seu e-mail" required>
      <button type="submit" class="px-btn px-btn--primary">Avisar</button>
    </div>
    {%- if form.posted_successfully? -%}<p class="px-newsletter__success">Obrigado!</p>{%- endif -%}
  {%- endform -%}
</p>

{% schema %}
{
  "name": "Página de senha",
  "settings": [
    { "type": "textarea", "id": "message", "label": "Mensagem", "default": "Estamos preparando algo especial. Volte em breve." }
  ]
}
{% endschema %}

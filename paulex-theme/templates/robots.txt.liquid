{%- comment -%}
  Customizable robots.txt. Keeps Shopify defaults and explicitly exposes the sitemap.
{%- endcomment -%}
{%- for group in robots.default_groups -%}
{{ group.user_agent }}
{%- for rule in group.rules -%}
{{ rule }}
{%- endfor -%}
{%- if group.sitemap != blank %}
{{ group.sitemap }}
{%- endif -%}
{% endfor -%}

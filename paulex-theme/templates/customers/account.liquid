{%- comment -%} Customer account dashboard {%- endcomment -%}
<section class="px-account page-width px-account--wide">
  <header class="px-account__header">
    <h1 class="px-account__title">{{ 'customer.account.title' | t }}</h1>
    <a href="{{ routes.account_logout_url }}" class="px-account__link">{{ 'customer.account.logout' | t }}</a>
  </header>

  <div class="px-account__grid">
    <div class="px-account__orders">
      <h2>{{ 'customer.orders.title' | t }}</h2>
      {%- if customer.orders.size > 0 -%}
        <table class="px-account__table">
          <thead>
            <tr>
              <th>{{ 'customer.orders.order_number' | t }}</th>
              <th>{{ 'customer.orders.date' | t }}</th>
              <th>{{ 'customer.orders.status' | t }}</th>
              <th>{{ 'customer.orders.total' | t }}</th>
            </tr>
          </thead>
          <tbody>
            {%- for order in customer.orders -%}
              <tr>
                <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
                <td>{{ order.created_at | date: '%d/%m/%Y' }}</td>
                <td>{{ order.financial_status_label }}</td>
                <td>{{ order.total_price | money }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
      {%- else -%}
        <p>{{ 'customer.orders.none' | t }}</p>
      {%- endif -%}
    </div>

    <aside class="px-account__sidebar">
      <h2>{{ 'customer.account.details' | t }}</h2>
      <p>{{ customer.name }}</p>
      {%- if customer.default_address -%}
        <address>{{ customer.default_address | format_address }}</address>
      {%- endif -%}
      <a href="{{ routes.account_addresses_url }}" class="px-btn px-btn--ghost">{{ 'customer.account.view_addresses' | t }}</a>
    </aside>
  </div>
</section>

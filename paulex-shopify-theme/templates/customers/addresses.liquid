{%- comment -%} Customer addresses (managed by Shopify's address form helpers) {%- endcomment -%}
<section class="px-account page-width px-account--wide">
  <header class="px-account__header">
    <h1 class="px-account__title">{{ 'customer.account.view_addresses' | t }}</h1>
    <a href="{{ routes.account_url }}" class="px-account__link">&larr; {{ 'customer.account.title' | t }}</a>
  </header>

  {%- paginate customer.addresses by 5 -%}
    <div class="px-account__card" data-reveal>
      <h2>Novo endereço</h2>
      {%- form 'customer_address', customer.new_address -%}
        {%- render 'address-fields', form: form, id_suffix: 'New' -%}
        <button type="submit" class="px-btn px-btn--primary">Salvar endereço</button>
      {%- endform -%}
    </div>

    {%- for address in customer.addresses -%}
      <div class="px-account__card" data-reveal>
        {%- if address == customer.default_address -%}<span class="px-badge px-badge--sale">Padrão</span>{%- endif -%}
        <address>{{ address | format_address }}</address>
        <details>
          <summary class="px-account__link">Editar</summary>
          {%- form 'customer_address', address -%}
            {%- render 'address-fields', form: form, id_suffix: address.id -%}
            <button type="submit" class="px-btn px-btn--primary">Atualizar</button>
            <button type="button" class="px-btn px-btn--ghost" onclick="if(confirm('Remover este endereço?')){Shopify.CustomerAddress.destroy({{ address.id }}, '{{ address.url_to_destroy }}');}">Remover</button>
          {%- endform -%}
        </details>
      </div>
    {%- endfor -%}

    {% render 'pagination', paginate: paginate %}
  {%- endpaginate -%}
</section>

<script src="{{ 'shopify_common.js' | shopify_asset_url }}" defer></script>
<script>
  window.addEventListener('DOMContentLoaded', function () {
    if (window.Shopify && Shopify.CountryProvinceSelector) {
      document.querySelectorAll('[data-address-country]').forEach(function (countrySelect) {
        var suffix = countrySelect.id.replace('AddressCountry', '');
        new Shopify.CountryProvinceSelector(
          countrySelect.id,
          'AddressProvince' + suffix,
          { hideElement: 'AddressProvinceContainer' + suffix }
        );
      });
    }
  });
</script>

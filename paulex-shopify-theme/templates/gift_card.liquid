{%- comment -%} Gift card display {%- endcomment -%}
<section class="px-account page-width">
  <div class="px-account__card" style="text-align:center" data-reveal>
    <img src="{{ 'px-logo.jpeg' | asset_url }}" alt="{{ shop.name }}" width="96" height="72" style="margin:0 auto 1.5rem">
    <h1 class="px-account__title">Vale-presente</h1>
    <p class="px-price__current" style="font-size:3.2rem;display:block;margin:1rem 0">{{ gift_card.balance | money }}</p>

    <div style="background:var(--color-surface);border-radius:var(--radius);padding:2rem;margin:1.5rem 0">
      {{ gift_card.qr_identifier }}
      <p style="font-family:monospace;font-size:2rem;letter-spacing:.2em;margin:1rem 0">{{ gift_card.code | format_code }}</p>
    </div>

    {%- if gift_card.expired -%}
      <p style="color:var(--color-sale)">Este vale-presente expirou.</p>
    {%- elsif gift_card.expires_on -%}
      <p>Válido até {{ gift_card.expires_on | date: '%d/%m/%Y' }}</p>
    {%- endif -%}

    <a href="{{ shop.url }}" class="px-btn px-btn--primary px-btn--block">Usar agora</a>
  </div>
</section>
{{ 'theme.css' | asset_url | stylesheet_tag }}
{% style %}
  :root { --color-primary: {{ settings.color_primary }}; --color-accent: {{ settings.color_accent }}; --gradient-hero: {{ settings.gradient_hero }}; --radius: {{ settings.corner_radius }}px; --radius-sm: 8px; --color-surface: {{ settings.color_surface }}; --color-text: {{ settings.color_text }}; --color-text-rgb: 17,17,17; --color-bg: #fff; }
{% endstyle %}

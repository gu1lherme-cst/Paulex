<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="{{ settings.color_primary }}">
    <link rel="canonical" href="{{ canonical_url }}">
    <title>{{ page_title }} &ndash; {{ shop.name }}</title>
    {%- render 'meta-tags' -%}
    {{ content_for_header }}
    {% style %}
      :root {
        --color-primary: {{ settings.color_primary }};
        --color-accent: {{ settings.color_accent }};
        --gradient-hero: {{ settings.gradient_hero }};
        --radius: {{ settings.corner_radius }}px;
      }
    {% endstyle %}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
  </head>
  <body class="template-password">
    <main class="px-password" role="main">
      <div class="px-password__card">
        <div class="px-password__logo">
          <img src="{{ 'px-logo.jpeg' | asset_url }}" alt="{{ shop.name }}" width="96" height="72">
        </div>
        {{ content_for_layout }}
      </div>
    </main>
  </body>
</html>

{%- comment -%}
  SEO: Open Graph, Twitter Cards and JSON-LD structured data (Schema.org).
  Rendered from the <head> in layout/theme.liquid and password.liquid.
{%- endcomment -%}

{%- liquid
  if template.name == 'product' and product
    assign og_title = product.title | strip_html
    assign og_type = 'product'
    assign og_description = product.description | strip_html | truncatewords: 50
    if product.featured_media
      assign og_image = product.featured_media | image_url: width: 1200
    endif
  elsif template.name == 'collection' and collection
    assign og_title = collection.title | strip_html
    assign og_type = 'website'
    assign og_description = collection.description | strip_html | truncatewords: 50
    if collection.image
      assign og_image = collection.image | image_url: width: 1200
    endif
  elsif template.name == 'article' and article
    assign og_title = article.title | strip_html
    assign og_type = 'article'
    assign og_description = article.excerpt_or_content | strip_html | truncatewords: 50
    if article.image
      assign og_image = article.image | image_url: width: 1200
    endif
  else
    assign og_title = page_title | default: shop.name
    assign og_type = 'website'
    assign og_description = page_description | default: shop.description | default: shop.name
  endif

  unless og_image
    if settings.share_image
      assign og_image = settings.share_image | image_url: width: 1200
    endif
  endunless
-%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">
<meta property="og:locale" content="{{ request.locale.iso_code | replace: '-', '_' }}">
{%- if og_image -%}
  <meta property="og:image" content="http:{{ og_image }}">
  <meta property="og:image:secure_url" content="https:{{ og_image }}">
  <meta property="og:image:width" content="1200">
{%- endif -%}

<meta name="twitter:card" content="summary_large_image">
{%- if settings.seo_twitter_handle != blank -%}
  <meta name="twitter:site" content="{{ settings.seo_twitter_handle }}">
{%- endif -%}
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">
{%- if og_image -%}
  <meta name="twitter:image" content="https:{{ og_image }}">
{%- endif -%}

{%- comment -%} Organization + WebSite (with SearchAction) on the homepage {%- endcomment -%}
{%- if request.page_type == 'index' -%}
  {%- liquid
    assign org_logo = ''
    if shop.brand.logo
      assign org_logo = shop.brand.logo | image_url: width: 512 | prepend: 'https:'
    elsif settings.share_image
      assign org_logo = settings.share_image | image_url: width: 512 | prepend: 'https:'
    endif
    assign social = ''
    if settings.social_instagram != blank
      assign social = social | append: settings.social_instagram | append: ','
    endif
    if settings.social_facebook != blank
      assign social = social | append: settings.social_facebook | append: ','
    endif
    if settings.social_youtube != blank
      assign social = social | append: settings.social_youtube | append: ','
    endif
    if settings.social_tiktok != blank
      assign social = social | append: settings.social_tiktok | append: ','
    endif
  -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | append: '/' | json }}
      {%- if org_logo != blank %},
      "logo": {{ org_logo | json }}
      {%- endif -%}
      {%- if shop.brand.short_description != blank %},
      "description": {{ shop.brand.short_description | json }}
      {%- endif -%}
      {%- if social != blank %},
      "sameAs": [
        {%- assign social_list = social | split: ',' -%}
        {%- for s in social_list -%}{{ s | json }}{%- unless forloop.last %},{% endunless -%}{%- endfor -%}
      ]
      {%- endif -%}
    }
  </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | append: '/' | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ shop.url | append: routes.search_url | append: '?q={search_term_string}' | json }},
        "query-input": "required name=search_term_string"
      }
    }
  </script>
{%- endif -%}

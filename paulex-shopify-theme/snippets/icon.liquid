{%- comment -%}
  Renders an inline SVG icon from a central set.
  Usage: {% render 'icon', name: 'cart' %}
  Accepts: name (required), class (optional)
{%- endcomment -%}
{%- liquid
  assign icon_class = 'px-icon'
  if class
    assign icon_class = icon_class | append: ' ' | append: class
  endif
-%}

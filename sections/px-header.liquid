{%- comment -%}
  Paulex header: fixed white bar, logo left, centered nav, actions right.
  Shrinks and gains shadow on scroll (handled by sticky-header element in theme.js).
{%- endcomment -%}
{%- assign whatsapp_number = settings.social_whatsapp | remove: '+' | remove: ' ' | remove: '-' | remove: '(' | remove: ')' | remove: '.' -%}
<sticky-header class="px-header{% if section.settings.sticky %} px-header--sticky{% endif %}" data-sticky-header>
  <div class="px-header__inner page-width">
    <a class="px-header__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        {%- assign logo_height = section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio -%}
        {{
          section.settings.logo
          | image_url: width: 240
          | image_tag:
            widths: '120,160,200,240',
            loading: 'eager',
            class: 'px-header__logo-img',
            alt: shop.name,
            height: logo_height,
            width: section.settings.logo_width
        }}
      {%- else -%}
        <img
          src="{{ 'px-logo.jpeg' | asset_url }}"
          alt="{{ shop.name }}"
          class="px-header__logo-img"
          width="84"
          height="63"
          loading="eager"
        >
      {%- endif -%}
    </a>

    <nav class="px-header__nav" aria-label="{{ 'general.accessibility.menu' | t }}">
      <ul class="px-header__menu">
        {%- for link in section.settings.menu.links -%}
          <li class="px-header__menu-item{% if link.links != blank %} has-dropdown{% endif %}">
            <a
              href="{{ link.url }}"
              class="px-header__link{% if link.active or link.child_active %} is-active{% endif %}"
              {% if link.links != blank %}aria-haspopup="true"{% endif %}
            >
              {{ link.title }}
              {%- if link.links != blank -%}{% render 'icon', name: 'chevron-down', class: 'px-header__caret' %}{%- endif -%}
            </a>
            {%- if link.links != blank -%}
              <div class="px-header__dropdown">
                <ul>
                  {%- for child in link.links -%}
                    <li><a href="{{ child.url }}" class="{% if child.active %}is-active{% endif %}">{{ child.title }}</a></li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}
          </li>
        {%- else -%}
          <li class="px-header__menu-item"><a class="px-header__link" href="{{ routes.root_url }}">Início</a></li>
          <li class="px-header__menu-item"><a class="px-header__link" href="{{ routes.collections_url }}/papelaria">Papelaria</a></li>
          <li class="px-header__menu-item"><a class="px-header__link" href="{{ routes.collections_url }}/utilidades">Utilidades</a></li>
          <li class="px-header__menu-item"><a class="px-header__link" href="{{ routes.collections_url }}/descartaveis">Descartáveis</a></li>
          <li class="px-header__menu-item"><a class="px-header__link" href="{{ routes.collections_url }}/brinquedos">Brinquedos</a></li>
          <li class="px-header__menu-item"><a class="px-header__link" href="{{ routes.collections_url }}/informatica">Informática</a></li>
          <li class="px-header__menu-item"><a class="px-header__link" href="{{ routes.collections_url }}/tv-e-acessorios">TV e acessórios</a></li>
        {%- endfor -%}
      </ul>
    </nav>

    <div class="px-header__actions">
      {%- if section.settings.show_account -%}
        <a class="px-header__action px-header__action--account" href="{{ routes.account_url }}" aria-label="{{ 'customer.account.title' | t }}">
          {% render 'icon', name: 'account' %}
          <span class="px-header__action-label">{{ 'customer.account.title' | t }}</span>
        </a>
      {%- endif -%}
      {%- if section.settings.show_search -%}
        <button type="button" class="px-header__action" data-search-open aria-label="{{ 'general.search.search' | t }}">
          {% render 'icon', name: 'search' %}
        </button>
      {%- endif -%}
      <a class="px-header__action px-header__cart" href="{{ routes.cart_url }}" data-cart-toggle aria-label="{{ 'cart.title' | t }}">
        {% render 'icon', name: 'cart' %}
        <span class="px-header__cart-count{% if cart.item_count == 0 %} is-empty{% endif %}" data-cart-count>{{ cart.item_count }}</span>
      </a>
      <button type="button" class="px-header__action px-header__burger" data-mobile-open aria-label="{{ 'general.accessibility.open_menu' | t }}" aria-expanded="false">
        {% render 'icon', name: 'menu' %}
      </button>
    </div>
  </div>
</sticky-header>

{%- comment -%} Mobile slide-in navigation {%- endcomment -%}
<div class="px-mobile-nav" data-mobile-nav aria-hidden="true">
  <div class="px-mobile-nav__overlay" data-mobile-close tabindex="-1"></div>
  <aside class="px-mobile-nav__panel" role="dialog" aria-modal="true" aria-label="{{ 'general.accessibility.menu' | t }}">
    <div class="px-mobile-nav__head">
      <img src="{{ 'px-logo.jpeg' | asset_url }}" alt="{{ shop.name }}" width="64" height="48" loading="lazy">
      <button type="button" class="px-mobile-nav__close" data-mobile-close aria-label="{{ 'general.accessibility.close_menu' | t }}">
        {% render 'icon', name: 'close' %}
      </button>
    </div>
    <nav class="px-mobile-nav__menu" aria-label="{{ 'general.accessibility.menu' | t }}">
      {%- for link in section.settings.menu.links -%}
        {%- if link.links != blank -%}
          <details class="px-mobile-nav__group">
            <summary>{{ link.title }} {% render 'icon', name: 'chevron-down' %}</summary>
            <div class="px-mobile-nav__sub">
              <a href="{{ link.url }}">{{ link.title }}</a>
              {%- for child in link.links -%}
                <a href="{{ child.url }}">{{ child.title }}</a>
              {%- endfor -%}
            </div>
          </details>
        {%- else -%}
          <a class="px-mobile-nav__link" href="{{ link.url }}">{{ link.title }}</a>
        {%- endif -%}
      {%- else -%}
        <a class="px-mobile-nav__link" href="{{ routes.root_url }}">Início</a>
        <a class="px-mobile-nav__link" href="{{ routes.collections_url }}/papelaria">Papelaria</a>
        <a class="px-mobile-nav__link" href="{{ routes.collections_url }}/utilidades">Utilidades</a>
        <a class="px-mobile-nav__link" href="{{ routes.collections_url }}/descartaveis">Descartáveis</a>
        <a class="px-mobile-nav__link" href="{{ routes.collections_url }}/brinquedos">Brinquedos</a>
        <a class="px-mobile-nav__link" href="{{ routes.collections_url }}/informatica">Informática</a>
        <a class="px-mobile-nav__link" href="{{ routes.collections_url }}/tv-e-acessorios">TV e acessórios</a>
      {%- endfor -%}
    </nav>
    <div class="px-mobile-nav__footer">
      <a href="{{ routes.account_url }}" class="px-mobile-nav__link">{% render 'icon', name: 'account' %} {{ 'customer.account.title' | t }}</a>
      {%- if whatsapp_number != blank -%}
        <a href="https://wa.me/{{ whatsapp_number }}" class="px-mobile-nav__link" target="_blank" rel="noopener">{% render 'icon', name: 'whatsapp' %} {{ 'general.social.whatsapp' | t }}</a>
      {%- endif -%}
    </div>
  </aside>
</div>

{% schema %}
{
  "name": "t:sections.header.name",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "t:sections.header.logo" },
    { "type": "range", "id": "logo_width", "min": 60, "max": 200, "step": 4, "unit": "px", "label": "t:sections.header.logo_width", "default": 84 },
    { "type": "link_list", "id": "menu", "label": "t:sections.header.menu", "default": "main-menu" },
    { "type": "checkbox", "id": "sticky", "label": "t:sections.header.sticky", "default": true },
    { "type": "checkbox", "id": "show_account", "label": "t:sections.header.show_account", "default": true },
    { "type": "checkbox", "id": "show_search", "label": "t:sections.header.show_search", "default": true }
  ]
}
{% endschema %}

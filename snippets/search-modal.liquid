{%- comment -%}
  Full-screen instant search with predictive results.
  Driven by predictive-search custom element in theme.js.
{%- endcomment -%}
<search-modal id="SearchModal" class="px-search-modal" data-search-modal aria-hidden="true">
  <div class="px-search-modal__overlay" data-search-close tabindex="-1"></div>
  <div class="px-search-modal__panel" role="dialog" aria-modal="true" aria-label="{{ 'general.search.search' | t }}">
    <form action="{{ routes.search_url }}" method="get" role="search" class="px-search-modal__form" data-predictive-search-form>
      <input type="hidden" name="type" value="product,collection,page,article">
      {% render 'icon', name: 'search', class: 'px-search-modal__icon' %}
      <input
        type="search"
        name="q"
        class="px-search-modal__input"
        placeholder="{{ 'general.search.placeholder' | t }}"
        aria-label="{{ 'general.search.search' | t }}"
        autocomplete="off"
        autocorrect="off"
        spellcheck="false"
        data-predictive-search-input
      >
      <button type="button" class="px-search-modal__close" data-search-close aria-label="{{ 'general.accessibility.close' | t }}">
        {% render 'icon', name: 'close' %}
      </button>
    </form>
    <div class="px-search-modal__results" data-predictive-search-results aria-live="polite"></div>
  </div>
</search-modal>

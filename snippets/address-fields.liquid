{%- comment -%}
  Shared address form fields. Accepts:
  - form {Object} required
  - id_suffix {String} optional, used to keep country/province IDs unique per form
{%- endcomment -%}
{%- liquid
  assign address_id_suffix = id_suffix | default: 'New'
  assign country_id = 'AddressCountry' | append: address_id_suffix
  assign province_id = 'AddressProvince' | append: address_id_suffix
  assign province_container_id = 'AddressProvinceContainer' | append: address_id_suffix
-%}
{{ form.errors | default_errors }}
<div class="px-account__row">
  <div><label>Nome</label>{{ form.first_name }}</div>
  <div><label>Sobrenome</label>{{ form.last_name }}</div>
</div>
<label>Empresa</label>{{ form.company }}
<label>Endereço</label>{{ form.address1 }}
<label>Complemento</label>{{ form.address2 }}
<div class="px-account__row">
  <div><label>Cidade</label>{{ form.city }}</div>
  <div><label>CEP</label>{{ form.zip }}</div>
</div>
<div class="px-account__row">
  <div>
    <label for="{{ country_id }}">País</label>
    {{ form.country | replace: '<select', '<select id="ADDRESS_COUNTRY_ID" data-address-country' | replace: 'ADDRESS_COUNTRY_ID', country_id }}
  </div>
  <div>
    <label for="{{ province_id }}">Estado</label>
    <div id="{{ province_container_id }}" data-address-province-container>{{ form.province | replace: '<select', '<select id="ADDRESS_PROVINCE_ID"' | replace: 'ADDRESS_PROVINCE_ID', province_id }}</div>
  </div>
</div>
<label>Telefone</label>{{ form.phone }}
<label class="px-checkbox">{{ form.set_as_default_checkbox }} Definir como endereço padrão</label>
